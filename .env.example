# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-for-embed

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Provider: Wati.io or direct Meta Cloud API
WHATSAPP_API_URL=https://live-server.wati.io/api/v1
WHATSAPP_API_TOKEN=your-wati-bearer-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-token-32chars
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_WHATSAPP_NUMBER=628xxxxxxxxxx   # Admin WA for emergency alerts
ADMIN_SECRET=your-admin-secret-for-internal-api

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://girigocourier.vercel.app
NEXT_PUBLIC_APP_NAME=GiriGo Courier

# ── Feature flags ─────────────────────────────────────────────────────────────
DISPATCH_TIMEOUT_SECONDS=60
DISPATCH_MAX_ATTEMPTS=3
DISPATCH_RADIUS_KM=5
BASE_DELIVERY_FEE=5000
PER_KM_RATE=2000
BASE_DISTANCE_KM=2
COURIER_REVENUE_SHARE=0.85
